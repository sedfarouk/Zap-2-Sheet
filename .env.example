# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# WorkZappy Configuration
WORKZAPPY_TARGET_COLUMN=Done Tickets
WORKZAPPY_WEBHOOK_SECRET=

# Microsoft Graph API Configuration
# Get these from Azure Portal > App Registrations
MICROSOFT_TENANT_ID=your-tenant-id-here
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here

# SharePoint Configuration
# Extract these IDs using the verify_graph_auth.py script
SHAREPOINT_SITE_ID=your-site-id-here
SHAREPOINT_FILE_ID=your-file-id-here

# Excel Configuration
EXCEL_TICKET_ID_COLUMN=D
EXCEL_TICKET_ID_HIDDEN=true
